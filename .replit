modules = ["web", "bash", "nodejs-20", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BACKEND_PORT=8080 node -e \"const { spawn } = require('child_process'); const be = spawn('pnpm', ['--filter', '@workspace/api-server', 'run', 'dev'], { env: { ...process.env, PORT: '8080' }, stdio: 'inherit' }); const fe = spawn('pnpm', ['--filter', '@workspace/yookpay', 'run', 'dev'], { env: { ...process.env, PORT: '5000', BACKEND_PORT: '8080', BASE_PATH: '/' }, stdio: 'inherit' }); be.on('exit', c => process.exit(c)); fe.on('exit', c => process.exit(c));\""
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
PIXPAY_ENV = "production"

[userenv.shared]
APP_URL = "https://yookpay.replit.app"

[userenv.development]
PIXPAY_ENV = "production"

[[ports]]
localPort = 5000
externalPort = 80
