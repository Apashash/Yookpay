{
  "name": "yookpay",
  "version": "1.0.0",
  "license": "MIT",
  "main": "app.js",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node app.js",
    "build:frontend": "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/yookpay run build",
    "build:backend": "pnpm --filter @workspace/api-server run build",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
